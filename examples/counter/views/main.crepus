div flex flex-col gap-6 p-8
  span text-2xl font-bold
    "Count: {count}"
  span text-sm text-zinc-500
    "JS says this counter is {mood}. {next}."
  div flex flex-row gap-4
    button @click="Decrement" rounded-lg bg-zinc-800 text-white px-4 py-2
      "Decrement"
    button @click="Increment" rounded-lg bg-green-600 text-white px-4 py-2
      "Increment"
  span text-sm
    "Last tick: {timestamp}"
